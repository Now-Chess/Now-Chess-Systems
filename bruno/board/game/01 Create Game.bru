meta {
  name: Create Game
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/board/game
  body: json
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "white": {"id": "p1", "displayName": "Alice"},
    "black": {"id": "p2", "displayName": "Bob"},
    "timeControl": {
      "limitSeconds": 300,
      "incrementSeconds": 3
    }
  }
}
