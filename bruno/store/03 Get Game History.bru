meta {
  name: Get Game History
  type: http
  seq: 3
}

http {
  method: GET
  url: {{storeBaseUrl}}/game/history/{{playerId}}?offset=0&limit=20
  auth: none
}

headers {
  Accept: application/json
}

notes {
  Optional query parameters:
  - offset: Skip N records (default 0)
  - limit: Return N records (default 20)
}
