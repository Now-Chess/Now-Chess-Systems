meta {
  name: Decline Challenge
  type: http
  seq: 5
}

post {
  url: {{accountBaseUrl}}/challenge/{{challengeId}}/decline
  body: json
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "reason": "Not interested"
  }
}
