meta {
  name: Send Challenge
  type: http
  seq: 1
}

http {
  method: POST
  url: {{accountBaseUrl}}/challenge/{{username}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "timeControl": {
      "limitSeconds": 600,
      "incrementSeconds": 5
    }
  }
}
