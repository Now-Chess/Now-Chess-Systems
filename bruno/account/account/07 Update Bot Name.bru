meta {
  name: Update Bot Name
  type: http
  seq: 7
}

put {
  url: {{accountBaseUrl}}/account/bots/{{botId}}
  body: json
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "name": "ChessBot-Updated"
  }
}
